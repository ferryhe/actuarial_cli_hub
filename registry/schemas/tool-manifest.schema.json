{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ferryhe/actuarial_cli_hub/registry/schemas/tool-manifest.schema.json",
  "title": "Actuarial CLI Hub Tool Manifest",
  "type": "object",
  "additionalProperties": true,
  "required": ["id", "version", "name", "status", "category", "priority", "upstream", "conversion", "runtime", "io", "agent"],
  "properties": {
    "id": {"type": "string", "pattern": "^actuarial\\.[a-z0-9_.-]+$"},
    "version": {"type": "string"},
    "name": {"type": "string", "minLength": 1},
    "status": {"enum": ["cataloged", "manifested", "fixture-ready", "experimental", "stable", "external-reference"]},
    "category": {"type": "string"},
    "priority": {"enum": ["P0", "P1", "P1/P2", "P2", "P3", "P0/P1"]},
    "upstream": {
      "type": "object",
      "required": ["repo", "language"],
      "properties": {
        "repo": {"type": "string"},
        "package": {"type": "string"},
        "language": {"type": "string"},
        "license": {"type": "string"},
        "install": {"type": "string"}
      }
    },
    "conversion": {
      "type": "object",
      "required": ["class", "form", "dependencyWeight"],
      "properties": {
        "class": {"enum": ["python-library", "python-dsl", "python-model-runner", "julia-adapter", "r-adapter", "application-spike", "reference-pack", "catalog-importer"]},
        "form": {"type": "string"},
        "dependencyWeight": {"enum": ["light", "medium", "heavy", "optional", "reference-only"]},
        "readiness": {"type": "string"}
      }
    },
    "runtime": {
      "type": "object",
      "required": ["kind", "command", "allowedCommandPrefix"],
      "properties": {
        "kind": {"enum": ["cli", "optional-cli", "reference", "catalog"]},
        "command": {"type": "array", "items": {"type": "string"}},
        "allowedCommandPrefix": {"type": "string"},
        "timeoutMs": {"type": "integer", "minimum": 1000},
        "maxOutputBytes": {"type": "integer", "minimum": 1024}
      }
    },
    "io": {
      "type": "object",
      "required": ["inputSchema", "outputSchema", "artifacts"],
      "properties": {
        "inputSchema": {"type": "string"},
        "outputSchema": {"type": "string"},
        "artifacts": {"type": "array", "items": {"type": "string"}}
      }
    },
    "agent": {
      "type": "object",
      "required": ["useCases", "limitations"],
      "properties": {
        "skillPath": {"type": "string"},
        "useCases": {"type": "array", "items": {"type": "string"}},
        "limitations": {"type": "array", "items": {"type": "string"}}
      }
    }
  }
}
